# Copy this file to .env for local development (never commit .env to git)

# Required in production (Railway sets DATABASE_URL automatically)
# Leave empty locally to use SQLite fallback
DATABASE_URL=

# Flask session security — MUST be set in production
SECRET_KEY=your-random-secret-key-here

# Anthropic API Key (platform-managed — not exposed to users)
# Set this in Railway environment variables, not here
ANTHROPIC_API_KEY=

# Optional: Adzuna Job Search API
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
